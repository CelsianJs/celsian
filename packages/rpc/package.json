{
  "name": "@celsian/rpc",
  "version": "0.3.18",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@celsian/schema": "workspace:*"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CelsianJs/celsian.git",
    "directory": "packages/rpc"
  },
  "homepage": "https://github.com/CelsianJs/celsian#readme",
  "bugs": {
    "url": "https://github.com/CelsianJs/celsian/issues"
  },
  "description": "Type-safe RPC utilities for CelsianJS",
  "keywords": [
    "celsian",
    "rpc",
    "typescript",
    "api"
  ],
  "sideEffects": false
}

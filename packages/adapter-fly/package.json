{
  "name": "@celsian/adapter-fly",
  "version": "0.2.0",
  "description": "CelsianJS adapter for Fly.io — generates fly.toml, Dockerfile, and multi-region config",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@celsian/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "name": "celsian-monorepo",
  "version": "0.5.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "bench": "pnpm --filter celsian-benchmarks exec tsx run.ts",
    "test:bench": "CELSIAN_INCLUDE_BENCH=1 vitest run packages/cache/test/bench.test.ts",
    "verify:publish": "pnpm assert:release-private && pnpm assert:public-metadata && scripts/verify-publish.sh",
    "audit:release": "pnpm audit --prod --audit-level=moderate",
    "setup:pnpm": "corepack enable && corepack prepare pnpm@9.15.0 --activate",
    "lint:ci": "biome ci .",
    "verify:registry": "node scripts/verify-registry-install.mjs",
    "assert:release-private": "node scripts/assert-release-private.mjs",
    "assert:public-metadata": "node scripts/assert-public-metadata.mjs",
    "docs": "typedoc",
    "size": "size-limit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "pnpm": {
    "overrides": {
      "qs@<6.15.2": "^6.15.2",
      "path-to-regexp@>=8.0.0 <8.4.0": "^8.4.0",
      "fast-uri@<3.1.2": "^3.1.2",
      "hyperid@<4.0.0": "^4.0.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "size-limit": "^12.1.0",
    "@sinclair/typebox": "^0.34.50",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autocannon": "^8.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.4.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}

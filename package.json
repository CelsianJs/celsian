{
  "name": "celsian-monorepo",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish --provenance",
    "bench": "pnpm --filter celsian-benchmarks exec tsx run.ts",
    "test:bench": "CELSIAN_INCLUDE_BENCH=1 vitest run packages/cache/test/bench.test.ts",
    "verify:publish": "scripts/verify-publish.sh",
    "audit:release": "pnpm audit --prod --audit-level=moderate",
    "setup:pnpm": "corepack enable && corepack prepare pnpm@9.15.0 --activate",
    "lint:ci": "biome ci ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.27.0",
    "@sinclair/typebox": "^0.34.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^25.2.3",
    "autocannon": "^8.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "vite@>=7.0.0 <=7.3.1": "7.3.3",
      "rollup@>=4.0.0 <4.59.0": "4.60.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.14",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "defu@<=6.1.4": "6.1.5",
      "fast-uri@<=3.1.1": "3.1.2"
    }
  }
}

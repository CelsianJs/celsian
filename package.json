{
  "name": "celsian-monorepo",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "bench": "pnpm --filter celsian-benchmarks exec tsx run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.31.0",
    "@sinclair/typebox": "^0.34.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autocannon": "^8.0.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
